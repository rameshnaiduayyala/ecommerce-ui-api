# Server Config
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Database Config
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ecommerce?schema=public"

# Redis Config
REDIS_URL="redis://localhost:6379"

# JWT Config
JWT_ACCESS_SECRET="super-secret-access-key-should-be-long-and-secure-12345!"
JWT_REFRESH_SECRET="super-secret-refresh-key-should-be-long-and-secure-12345!"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Storage Configuration
# STORAGE_DRIVER options: LOCAL, S3
STORAGE_DRIVER=LOCAL
UPLOAD_DIR="./uploads"

# AWS S3 Settings (Used if STORAGE_DRIVER=S3, or for MinIO locally)
AWS_ACCESS_KEY_ID="minioadmin"
AWS_SECRET_ACCESS_KEY="minioadmin"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="ecommerce-bucket"
AWS_S3_ENDPOINT="http://localhost:9000" # Set for Local MinIO, leave empty for real AWS S3
AWS_S3_FORCE_PATH_STYLE=true

# Twilio SMS Config (Mocked in dev unless filled)
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_FROM_NUMBER="+1234567890"

# SMTP Email Config (Nodemailer / Mailhog setup)
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="no-reply@enterprise-ecommerce.com"

# Payment Gateways (Mocked in dev unless filled)
STRIPE_SECRET_KEY="sk_test_51..."
STRIPE_WEBHOOK_SECRET="whsec_..."
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxx"

# Shipping Providers
SHIPROCKET_EMAIL="admin@enterprise-ecommerce.com"
SHIPROCKET_PASSWORD="password"

# Security Controls
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
BRUTE_FORCE_MAX_ATTEMPTS=5
ACCOUNT_LOCK_DURATION_MINS=15
